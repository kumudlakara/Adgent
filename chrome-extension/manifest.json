{
  "manifest_version": 3,
  "name": "Addie Demo Banner",
  "description": "Injects an interactive ad agent banner on any website.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.reddit.com/*",
    "*://*.techcrunch.com/*",
    "*://news.ycombinator.com/*",
    "*://*.stackoverflow.com/*",
    "http://localhost:8787/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.reddit.com/*",
        "*://*.techcrunch.com/*",
        "*://news.ycombinator.com/*",
        "*://*.stackoverflow.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Addie Demo"
  },
  "web_accessible_resources": [
    {
      "resources": ["products.json", "campaign.json", "images/*"],
      "matches": [
        "*://*.reddit.com/*",
        "*://*.techcrunch.com/*",
        "*://news.ycombinator.com/*",
        "*://*.stackoverflow.com/*"
      ]
    }
  ]
}
